#: src/Plugin.php:122
msgid "PhoenixWP Fix — German Market DHL & WCML requires WooCommerce."
msgstr "PhoenixWP Fix — German Market DHL & WCML erfordert WooCommerce."

#: src/Plugin.php:128
msgid "PhoenixWP Fix — German Market DHL & WCML: activate German Market and WCML multi-currency for full functionality."
msgstr "PhoenixWP Fix — German Market DHL & WCML: Aktivieren Sie German Market und WCML-Multiwährung für die volle Funktionalität."

#: src/Install.php:37
msgid "PhoenixWP Fix — German Market DHL & WCML requires WordPress 6.7+, PHP 8.2+, and WooCommerce."
msgstr "PhoenixWP Fix — German Market DHL & WCML erfordert WordPress 6.7+, PHP 8.2+ und WooCommerce."

#: src/Install.php:38
msgid "Plugin Activation Error"
msgstr "Fehler bei der Plugin-Aktivierung"

#: src/Admin/Settings_Page.php:52
#: src/Admin/Settings_Page.php:53
msgid "GM DHL WCML Fix"
msgstr "GM DHL WCML-Fix"

#: src/Admin/Settings_Page.php:107
msgid "PhoenixWP Fix — German Market DHL & WCML"
msgstr "PhoenixWP Fix — German Market DHL & WCML"

#: src/Admin/Settings_Page.php:109
msgid "WCML Multi-Currency Compatibility Fix"
msgstr "WCML-Multiwährungs-Kompatibilitätsfix"

#: src/Admin/Settings_Page.php:110
msgid "— DHL free-shipping thresholds and shipping costs."
msgstr "— DHL-Versandkostenfrei-Schwellen und Versandkosten."

#: src/Admin/Settings_Page.php:112
msgid "German Market DHL International Address Fix"
msgstr "German Market DHL Internationaler Adress-Fix"

#: src/Admin/Settings_Page.php:113
msgid "— street/house-number parsing for DHL labels."
msgstr "— Straßen-/Hausnummern-Parsing für DHL-Labels."

#: src/Admin/Settings_Page.php:116
msgid "Requires German Market (DHL add-on) and WCML multi-currency — not included."
msgstr "Erfordert German Market (DHL-Add-on) und WCML-Multiwährung — nicht enthalten."

#: src/Admin/Settings_Page.php:127
msgid "DHL thresholds"
msgstr "DHL-Schwellen"

#: src/Admin/Settings_Page.php:131
msgid "Convert free/minimum amounts (EUR) with WCML before comparing cart totals"
msgstr "Gratis-/Mindestbeträge (EUR) mit WCML umrechnen, bevor Warenkorb-Summen verglichen werden"

#: src/Admin/Settings_Page.php:134
msgid "Targets dhl_home_delivery, dhl_packstation, dhl_parcelshops."
msgstr "Betrifft dhl_home_delivery, dhl_packstation, dhl_parcelshops."

#: src/Admin/Settings_Page.php:139
msgid "DHL shipping costs"
msgstr "DHL-Versandkosten"

#: src/Admin/Settings_Page.php:143
msgid "Convert configured DHL shipping costs (EUR) with WCML on checkout"
msgstr "Konfigurierte DHL-Versandkosten (EUR) mit WCML im Checkout umrechnen"

#: src/Admin/Settings_Page.php:146
msgid "Converts flat rates such as 5,00 EUR / 15,00 EUR to the active currency (WCML does not convert custom GM DHL methods automatically)."
msgstr "Rechnet Pauschalen wie 5,00 EUR / 15,00 EUR in die aktive Währung um (WCML konvertiert GM-DHL-Methoden nicht automatisch)."

#: src/Admin/Settings_Page.php:151
msgid "International address"
msgstr "Internationale Adresse"

#: src/Admin/Settings_Page.php:155
msgid "Fix number-first addresses (e.g. France) for DHL checkout and labels"
msgstr "Adressen mit Hausnummer zuerst (z. B. Frankreich) für DHL-Checkout und Labels korrigieren"

#: src/Admin/Settings_Page.php:172
msgid "German Market is not active. DHL integrations will not run."
msgstr "German Market ist nicht aktiv. DHL-Integrationen werden nicht ausgeführt."

#: src/Admin/Settings_Page.php:178
msgid "WCML multi-currency functions were not detected. Threshold conversion requires WooCommerce Multilingual."
msgstr "WCML-Multiwährungs-Funktionen wurden nicht erkannt. Schwellen-Umrechnung erfordert WooCommerce Multilingual."

#: src/Admin/Settings_Page.php:184
msgid "Dependencies OK — compatibility fixes are active."
msgstr "Abhängigkeiten OK — Kompatibilitätsfixes sind aktiv."
